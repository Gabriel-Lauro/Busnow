# URL do backend Go (server-side proxy — não exposta ao browser)
BACKEND_URL=http://localhost:8080

# URL direta do backend (só usada se NEXT_PUBLIC_USE_PROXY=false)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Usar proxy Next.js para evitar CORS (recomendado). Defina "false" para chamar o backend direto.
NEXT_PUBLIC_USE_PROXY=true

# Intervalo de atualização dos ônibus em SEGUNDOS. Padrão: 3
NEXT_PUBLIC_POLL_INTERVAL=3
