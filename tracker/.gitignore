*.pyc
*.pyo
*.pyd
.Python

# Distribuição / empacotamento
dist/
build/
*.egg-info/
*.egg

# Pip
pip-log.txt
pip-delete-this-directory.txt

# Pytest / cobertura
.pytest_cache/
.coverage
htmlcov/

# Variáveis de ambiente locais
.env
.env.local

# OS / Editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
